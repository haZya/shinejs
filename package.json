{
  "name": "shinejs-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for shinejs",
  "author": {
    "name": "Hasitha Wickramasinghe",
    "url": "https://hazya.dev"
  },
  "license": "MIT",
  "homepage": "https://github.com/haZya/shinejs#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/haZya/shinejs.git"
  },
  "bugs": {
    "url": "https://github.com/haZya/shinejs/issues"
  },
  "keywords": [
    "shinejs",
    "shine",
    "monorepo",
    "react",
    "typescript",
    "shadow",
    "text-shadow",
    "box-shadow"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --max-warnings 0 && npm run lint --workspaces --if-present",
    "lint:fix": "eslint . --fix && npm run lint:fix --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "dev": "npm run build && npm -w apps/demo run dev"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@shinejs/eslint-config": "*",
    "@types/node": "^25.2.0",
    "esbuild": "^0.27.2",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
