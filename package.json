{
  "name": "shinejs-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for shinejs",
  "author": {
    "name": "Hasitha Wickramasinghe",
    "url": "https://hazya.dev"
  },
  "contributors": [
    {
      "name": "Big Spaceship",
      "url": "https://github.com/bigspaceship"
    }
  ],
  "license": "MIT",
  "homepage": "https://shinejs.vercel.app/docs/getting-started/react-quick-start",
  "repository": {
    "type": "git",
    "url": "https://github.com/haZya/shinejs.git"
  },
  "bugs": {
    "url": "https://github.com/haZya/shinejs/issues"
  },
  "keywords": [
    "shinejs",
    "shine",
    "monorepo",
    "react",
    "typescript",
    "shadow",
    "text-shadow",
    "box-shadow"
  ],
  "scripts": {
    "build": "npm run build:packages && npm run build:apps",
    "build:packages": "npm -w packages/eslint-config run build && npm -w packages/shinejs run build",
    "build:apps": "npm run build:demo && npm run build:docs",
    "dev:demo": "npm run build:packages && npm -w apps/demo run dev",
    "build:demo": "npm run build:packages && npm -w apps/demo run build",
    "dev:docs": "npm run build:packages && npm -w apps/docs run dev",
    "build:docs": "npm run build:packages && npm -w apps/docs run build",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --max-warnings 0 && npm run lint --workspaces --if-present",
    "lint:fix": "eslint . --fix && npm run lint:fix --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@commitlint/config-conventional": "^20.4.2",
    "@shinejs/eslint-config": "*",
    "@types/node": "^25.3.0",
    "esbuild": "^0.27.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
