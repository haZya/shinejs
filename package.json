{
  "name": "shinejs-monorepo",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for shinejs",
  "author": "",
  "license": "MIT",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --max-warnings 0 && npm run lint --workspaces --if-present",
    "lint:fix": "eslint . --fix && npm run lint:fix --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "dev": "npm run build && npm -w apps/demo run dev"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@antfu/eslint-config": "^7.2.0",
    "@eslint-react/eslint-plugin": "^2.8.1",
    "@shinejs/eslint-config": "*",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-plugin-format": "^1.3.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jsdom": "^27.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
