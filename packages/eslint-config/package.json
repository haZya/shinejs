{
  "name": "@shinejs/eslint-config",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Shared ESLint configuration for shinejs projects.",
  "author": {
    "name": "Hasitha Wickramasinghe",
    "url": "https://hazya.dev"
  },
  "license": "MIT",
  "homepage": "https://shinejs.vercel.app/docs/getting-started/react-quick-start",
  "repository": {
    "type": "git",
    "url": "https://github.com/haZya/shinejs.git"
  },
  "bugs": {
    "url": "https://github.com/haZya/shinejs/issues"
  },
  "keywords": [
    "lint",
    "eslint",
    "config",
    "shinejs",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@cspell/eslint-plugin": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "^2.0.1"
  }
}
