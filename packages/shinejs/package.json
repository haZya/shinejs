{
  "name": "shinejs",
  "type": "module",
  "version": "1.0.0",
  "description": "Create pretty text-shadows and box-shadows with React support",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rimraf dist && npm run build:types && npm run build:js",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:js": "esbuild src/index.ts src/react/index.ts --bundle --format=esm --outdir=dist --minify --external:react --external:react-dom",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^2.9.3",
    "@shinejs/eslint-config": "*",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "jsdom": "^28.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
